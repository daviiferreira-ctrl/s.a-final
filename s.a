CREATE DATABASE IF NOT EXISTS vetket;
USE vetket;

CREATE TABLE usuario (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL,
    senha VARCHAR(255) NOT NULL,
    permissao_funcao VARCHAR(15) NOT NULL
);

CREATE TABLE veterinario (
    id_vet INT PRIMARY KEY,
    nome VARCHAR(100),
    especialidade VARCHAR(80),
    hora_atendi TIME,
    descricao VARCHAR(100)
);

CREATE TABLE pet (
    id_pet INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,
    especie VARCHAR(100) NOT NULL,
    foto_pet VARCHAR(200) NOT NULL,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
    ON DELETE CASCADE
);

CREATE TABLE telefone (
    id_tel INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,
    numero VARCHAR(50) NOT NULL,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
    ON DELETE CASCADE
);

CREATE TABLE pet_adocao (
    id_adocao INT AUTO_INCREMENT PRIMARY KEY,
    nome_pet VARCHAR(100),
    idade VARCHAR(30),
    estado_saude TEXT,
    contato_responsavel VARCHAR(100),
    disponivel_no_site TINYINT(1),
    id_usuario INT,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
);

CREATE TABLE consulta (
    id_agendamento INT AUTO_INCREMENT PRIMARY KEY,
    id_pet INT NOT NULL,
    id_vet INT NOT NULL,
    id_usuario INT NOT NULL,
    local TEXT NOT NULL,
    data DATE NOT NULL,
    hora TIME NOT NULL,
    descricao VARCHAR(100),
    FOREIGN KEY (id_pet) REFERENCES pet(id_pet)
    ON DELETE CASCADE,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
    ON DELETE CASCADE,
    FOREIGN KEY (id_vet) REFERENCES veterinario(id_vet)
    ON DELETE CASCADE
    ON UPDATE CASCADE
);

